<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:keepScreenOn="true">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_baseline_arrow_back_24"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif-medium"
            android:text="Fokus Pomodoro"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />
    </RelativeLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutHeader"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Task Selector Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTaskSelector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            app:cardBackgroundColor="#1E293B"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#334155"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_baseline_edit_24"
                    app:tint="#94A3B8" />

                <TextView
                    android:id="@+id/tvSelectedTask"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif"
                    android:hint="Pilih tugas untuk difokuskan..."
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#64748B"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_baseline_sort_24"
                    android:rotation="90"
                    app:tint="#94A3B8" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Timer Circle Container -->
        <RelativeLayout
            android:layout_width="280dp"
            android:layout_height="280dp">

            <!-- Background Ring -->
            <ProgressBar
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="100"
                android:progress="100"
                android:progressDrawable="@drawable/bg_circle_timer_track"
                style="?android:attr/progressBarStyleHorizontal" />

            <!-- Active Progress Ring -->
            <ProgressBar
                android:id="@+id/progressTimer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                android:max="1500"
                android:progress="1500"
                android:rotation="-90"
                android:progressDrawable="@drawable/bg_circle_timer_active"
                style="?android:attr/progressBarStyleHorizontal" />

            <!-- Time Text -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="25:00"
                    android:textColor="#FFFFFF"
                    android:textSize="56sp" />

                <TextView
                    android:id="@+id/tvTimerLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="WAKTU FOKUS (KETUK UNTUK MENGUBAH)"
                    android:textColor="#94A3B8"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:padding="16dp"
                android:text="Reset"
                android:textColor="#94A3B8"
                app:strokeColor="#334155" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartPause"
                android:layout_width="160dp"
                android:layout_height="64dp"
                android:backgroundTint="#EF4444"
                android:fontFamily="sans-serif-black"
                android:text="MULAI FOKUS"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:cornerRadius="32dp"
                app:elevation="8dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:alpha="0.6"
            android:fontFamily="sans-serif"
            android:text="Tetap fokus dan jauhkan gangguan."
            android:textColor="#94A3B8"
            android:textSize="14sp" />

    </LinearLayout>

</RelativeLayout>
