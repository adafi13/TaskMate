<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/tm_background"
    tools:context=".ui.SettingsActivity">

    <!-- Grand Clean Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingHorizontal="16dp"
        android:background="@color/tm_background">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_baseline_arrow_back_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_centerVertical="true"
            app:tint="@color/tm_black"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_settings"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:textColor="@color/tm_black"
            android:layout_centerInParent="true"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="64dp">

            <!-- Profile Spotlight Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/tm_divider"
                app:cardBackgroundColor="@color/tm_card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="32dp"
                    android:paddingBottom="24dp"
                    android:paddingHorizontal="24dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cardProfileImage"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            app:cardCornerRadius="50dp"
                            app:cardElevation="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:cardBackgroundColor="@color/chat_avatar_bg">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <ImageView
                                    android:id="@+id/imgProfile"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop"
                                    android:src="@drawable/ic_tm_logo"
                                    android:transitionName="profile_transform"
                                    android:padding="0dp"/>

                                <ProgressBar
                                    android:id="@+id/progressBarProfile"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:layout_gravity="center"
                                    android:indeterminateTint="@color/tm_green"
                                    android:visibility="gone"/>
                            </FrameLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:id="@+id/btnEditProfile"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            app:cardBackgroundColor="@color/tm_green"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            app:layout_constraintBottom_toBottomOf="@id/cardProfileImage"
                            app:layout_constraintEnd_toEndOf="@id/cardProfileImage">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="8dp"
                                android:src="@drawable/ic_baseline_add_24"
                                app:tint="@color/white"/>
                        </androidx.cardview.widget.CardView>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <LinearLayout
                        android:id="@+id/btnEditName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_user_name"
                            android:textColor="@color/tm_black"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:singleLine="true"
                            android:ellipsize="end"
                            android:maxWidth="250dp"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/ic_baseline_edit_24"
                            app:tint="@color/tm_gray_light"
                            tools:ignore="ContentDescription" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvUserEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/default_user_email"
                        android:textColor="@color/tm_gray"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_rounded_dialog"
                        android:backgroundTint="@color/chat_avatar_bg"
                        android:text="@string/label_user_taskmate"
                        android:textColor="@color/tm_green"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:textAllCaps="true"/>

                    <!-- Stats Section (Segmented Pills in Cardview) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStatsContainer"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/tm_divider"
                        app:cardBackgroundColor="@color/tm_background">
                        
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:weightSum="3">

                            <!-- Total Tasks -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:paddingVertical="12dp"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvStatTotal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/default_stat_value"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/tm_black"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/stat_task"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp"
                                    android:textColor="@color/tm_gray"/>
                            </LinearLayout>

                            <!-- Divider -->
                            <View 
                                android:layout_width="1dp" 
                                android:layout_height="36dp" 
                                android:background="@color/tm_divider" 
                                android:layout_gravity="center_vertical"/>

                            <!-- Done Tasks -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:paddingVertical="12dp"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvStatDone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/default_stat_value"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/tm_green"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/stat_done"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp"
                                    android:textColor="@color/tm_gray"/>
                            </LinearLayout>

                            <!-- Divider -->
                            <View 
                                android:layout_width="1dp" 
                                android:layout_height="36dp" 
                                android:background="@color/tm_divider" 
                                android:layout_gravity="center_vertical"/>

                            <!-- Pending Tasks -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:paddingVertical="12dp"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tvStatPending"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/default_stat_value"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/tm_red_error"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/stat_pending"
                                    android:textSize="12sp"
                                    android:layout_marginTop="2dp"
                                    android:textColor="@color/tm_gray"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- General Settings Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="32dp"
                android:layout_marginTop="32dp"
                android:text="@string/header_general_settings"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:textColor="@color/tm_gray_light"/>

            <!-- Settings Group 1: General -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/tm_divider"
                app:cardBackgroundColor="@color/tm_card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchNotification"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:text="@string/switch_notification"
                        android:textSize="16sp"
                        android:textColor="@color/tm_black"
                        app:thumbTint="@color/tm_green" />

                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:layout_marginStart="60dp" 
                        android:layout_marginEnd="20dp" 
                        android:background="@color/tm_divider"/>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchReminder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:text="@string/switch_reminder"
                        android:textSize="16sp"
                        android:textColor="@color/tm_black"
                        app:thumbTint="@color/tm_green" />

                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:layout_marginStart="60dp" 
                        android:layout_marginEnd="20dp" 
                        android:background="@color/tm_divider"/>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchDarkMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="14dp"
                        android:text="@string/switch_dark_mode"
                        android:textSize="16sp"
                        android:textColor="@color/tm_black"
                        app:thumbTint="@color/tm_green" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Others Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="32dp"
                android:layout_marginTop="32dp"
                android:text="@string/header_others"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                android:textColor="@color/tm_gray_light"/>

            <!-- Settings Group 2: Others -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/tm_divider"
                app:cardBackgroundColor="@color/tm_card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFeedback"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:text="@string/btn_feedback"
                        android:textColor="@color/tm_black"
                        android:textSize="16sp"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_email"
                        app:iconTint="@color/tm_gray"
                        app:iconPadding="16dp"
                        android:paddingVertical="14dp"
                        android:paddingHorizontal="16dp"/>

                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:layout_marginStart="60dp" 
                        android:layout_marginEnd="20dp" 
                        android:background="@color/tm_divider"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChangePassword"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:text="@string/btn_change_password"
                        android:textColor="@color/tm_black"
                        android:textSize="16sp"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_lock"
                        app:iconTint="@color/tm_gray"
                        app:iconPadding="16dp"
                        android:paddingVertical="14dp"
                        android:paddingHorizontal="16dp"/>

                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:layout_marginStart="60dp" 
                        android:layout_marginEnd="20dp" 
                        android:background="@color/tm_divider"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogout"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:text="@string/btn_logout"
                        android:textColor="@color/tm_black"
                        android:textSize="16sp"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_baseline_arrow_back_24"
                        app:iconTint="@color/tm_gray"
                        app:iconPadding="16dp"
                        android:paddingVertical="14dp"
                        android:paddingHorizontal="16dp"/>

                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:layout_marginStart="60dp" 
                        android:layout_marginEnd="20dp" 
                        android:background="@color/tm_divider"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeleteAccount"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:text="@string/btn_delete_account"
                        android:textColor="@color/tm_red_error"
                        android:textSize="16sp"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_baseline_delete_24"
                        app:iconTint="@color/tm_red_error"
                        app:iconPadding="16dp"
                        android:paddingVertical="14dp"
                        android:paddingHorizontal="16dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom Credits / Version -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="48dp"
                android:paddingHorizontal="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_credit"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/tm_gray"/>

                <TextView
                    android:id="@+id/tvAppVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/app_version_prefix"
                    android:textSize="12sp"
                    android:textColor="@color/tm_gray_light"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/app_academic_credit"
                    android:gravity="center"
                    android:textSize="10sp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/tm_gray_light"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>